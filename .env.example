# Host-level docker compose env file. Generated by docker-installer.sh.
INSTANCE_NAME=minestore
LICENSE_KEY=
APP_URL=https://store.example.com
APP_ENV=production
APP_DEBUG=false
TIMEZONE=UTC
LOCALE=en

# DB (bundled by default)
DB_DATABASE=minestore
DB_USERNAME=minestore
DB_PASSWORD=

# Where the host publishes the container's port 80
HTTP_PORT=80

# Path to the MineStoreCMS source repo for the build context.
# Default '.' assumes you are running compose from the repo root.
REPO_PATH=.
